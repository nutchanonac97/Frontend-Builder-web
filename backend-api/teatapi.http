# =================================================================
# ⚙️ หมวด 0: System Configuration (ตั้งค่าระบบ)
# =================================================================

### 0.1 📋 ดู Config ทั้งหมด
GET {{Host}}/api/integration-config
Accept: application/json

### 0.2 🔍 ดู Config ตาม Key
GET {{Host}}/api/integration-config/Email:SmtpHost
Accept: application/json

### 0.3 🟢 เพิ่ม/แก้ไข Config (Upsert) - ตั้งค่า SMTP Host
POST {{Host}}/api/integration-config
Content-Type: application/json

{
  "configKey": "Email:SmtpHost",
  "configValue": "smtp.gmail.com",
  "description": "SMTP Host for Gmail"
}

### 0.4 🟢 ตั้งค่า SMTP Port
POST {{Host}}/api/integration-config
Content-Type: application/json

{
  "configKey": "Email:SmtpPort",
  "configValue": "587",
  "description": "SMTP Port"
}

### 0.5 🟢 ตั้งค่า Email ผู้ส่ง
POST {{Host}}/api/integration-config
Content-Type: application/json

{
  "configKey": "Email:Username",
  "configValue": "band4869@gmail.com", 
  "description": "Email sender address"
}

### 0.6 🟢 ตั้งค่า App Password (สำคัญ!)
POST {{Host}}/api/integration-config
Content-Type: application/json

{
  "configKey": "Email:Password",
  "configValue": "cdvevrdutgusaorc", 
  "description": "Gmail App Password"
}

### 0.7 ❌ ลบ Config
DELETE {{Host}}/api/integration-config/Email:SmtpHost
Accept: application/json


### 0.12 📧 ตั้งค่า Email ผู้รับ (Admin Receiver)
# อีเมลที่จะคอยรับแจ้งเตือนจาก Contact Form
POST {{Host}}/api/integration-config
Content-Type: application/json

{
  "configKey": "Email:AdminReceiver",
  "configValue": "s65122519067@ssru.ac.th", 
  "description": "Email address for receiving contact form notifications"
}
### 0.13 🔍 ดู Email ผู้รับ (Get Admin Receiver)
GET {{Host}}/api/integration-config/Email:AdminReceiver
Accept: application/json

